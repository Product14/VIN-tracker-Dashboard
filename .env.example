# Local API: copy this file to `database_url.env` or `.env` in the repo root (both are gitignored).
# The server loads `database_url.env` first if it exists.

# Supabase project: https://supabase.com/dashboard/project/tzzruzwuvurcrwpdwnkz
# API URL (public — safe to commit in examples; keys are not)
SUPABASE_URL=https://tzzruzwuvurcrwpdwnkz.supabase.co
# Project Settings → API → service_role (server-only; used for Vini deployment_statuses table)
# SUPABASE_SECRET_KEY=

# Supabase PostgreSQL connection string (required — set in Vercel environment variables)
# Use the "Transaction" mode pooler URL (port 6543) for Vercel serverless:
#   Supabase dashboard → Project → Connect → Transaction mode
# Same project — paste the full "Transaction pooler" URI from Connect (do not commit real passwords).
# VIN_TRACKER_DATABASE_URL=postgresql://postgres.tzzruzwuvurcrwpdwnkz:[YOUR-PASSWORD]@aws-0-....pooler.supabase.com:6543/postgres
VIN_TRACKER_DATABASE_URL=

# Optional: override API base URL (leave unset — frontend and backend are co-deployed on Vercel)
# VITE_API_URL=

# Vini Account Health — Metabase public card JSON (same export columns as vini-dashboard CSV import).
# Fetched automatically on each POST /api/sync (Refresh) with VIN data. Example path: /api/public/card/<uuid>/query/json
# VINI_ROOFTOP_METABASE_URL=https://metabase.spyne.ai/api/public/card/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx/query/json
