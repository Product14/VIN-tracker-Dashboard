{
  "buildCommand": "node server/migrate.js && npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/(.*)",     "destination": "/index.html" }
  ],
  "functions": {
    "api/index.js": {
      "maxDuration": 600
    }
  },
  "crons": [
    { "path": "/api/scheduled-report",     "schedule": "30 6 * * *"  },
    { "path": "/api/scheduled-report",     "schedule": "30 12 * * *" },
    { "path": "/api/scheduled-report",     "schedule": "30 18 * * *" },
    { "path": "/api/send-daily-report",    "schedule": "0 12 * * *"   },
    { "path": "/api/process-report-queue", "schedule": "* 12-13 * * *" },
    { "path": "/api/cleanup-report-archive", "schedule": "0 3 * * *" }
  ]
}
